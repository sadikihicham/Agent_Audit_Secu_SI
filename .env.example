# ── GuardianOps AI — variables d'environnement ──
# Copier en .env :  cp .env.example .env

# PostgreSQL / TimescaleDB
POSTGRES_USER=guardian
POSTGRES_PASSWORD=guardian
POSTGRES_DB=guardianops
DB_PORT=5433

# Redis
REDIS_PORT=6380

# Ports applicatifs (décalés pour éviter les conflits avec d'autres projets locaux)
API_PORT=8800
WEB_PORT=3300

# Connexions internes (utilisées par l'API dans Docker — surchargées par docker-compose)
DATABASE_URL=postgresql+psycopg://guardian:guardian@db:5432/guardianops
REDIS_URL=redis://redis:6379/0

# Sécurité — OBLIGATOIRE : remplacer par une valeur aléatoire forte (min 32 caractères)
# Générer avec :  python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=REMPLACER_PAR_UNE_VALEUR_ALEATOIRE_FORTE
JWT_ALG=HS256
ACCESS_TOKEN_TTL_MINUTES=30
AGENT_TOKEN_TTL_DAYS=365

# CORS — origine autorisée du dashboard
CORS_ORIGINS=http://localhost:3300

# Alerting — seuils (cf. PLAN.md §3)
ALERT_CPU_THRESHOLD=90.0
ALERT_MEM_THRESHOLD=90.0
ALERT_DISK_THRESHOLD=90.0
ALERT_CPU_CONSECUTIVE_POINTS=3
ALERT_OFFLINE_MINUTES=2

# Application — "development" expose /docs ; "production" les désactive
ENVIRONMENT=development

# ── PRODUCTION uniquement (surcouche docker-compose.prod.yml) ──
# Domaine du dashboard ; l'API est servie sur api.<DOMAIN>.
DOMAIN=example.com
# Mot de passe Redis — OBLIGATOIRE en production (Redis --requirepass).
REDIS_PASSWORD=
# En production, remplacer aussi POSTGRES_PASSWORD ci-dessus par une valeur forte.
