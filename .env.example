# ── GuardianOps AI — variables d'environnement ──
# Copier en .env :  cp .env.example .env

# PostgreSQL / TimescaleDB
POSTGRES_USER=guardian
POSTGRES_PASSWORD=guardian
POSTGRES_DB=guardianops
DB_PORT=5433

# Redis
REDIS_PORT=6380

# Ports applicatifs (décalés pour éviter les conflits avec d'autres projets locaux)
API_PORT=8800
WEB_PORT=3300

# Connexions internes (utilisées par l'API dans Docker — surchargées par docker-compose)
DATABASE_URL=postgresql+psycopg://guardian:guardian@db:5432/guardianops
REDIS_URL=redis://redis:6379/0

# Sécurité — À CHANGER en production
JWT_SECRET=change-me-in-production-please-use-a-long-random-string
JWT_ALG=HS256
ACCESS_TOKEN_TTL_MINUTES=30
AGENT_TOKEN_TTL_DAYS=365

# CORS — origine autorisée du dashboard
CORS_ORIGINS=http://localhost:3300
