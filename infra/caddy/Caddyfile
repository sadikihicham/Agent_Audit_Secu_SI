# Reverse-proxy Caddy — TLS automatique (Let's Encrypt en prod, CA interne en local).
# Le dashboard et l'API sont servis sur deux sous-domaines distincts.
# WebSocket : Caddy gère l'upgrade automatiquement via reverse_proxy.

# Dashboard Next.js
{$DOMAIN} {
	encode gzip
	reverse_proxy web:3000
}

# API FastAPI (REST + WebSocket /ws)
# Upstreams DYNAMIQUES : Caddy ré-interroge le DNS Docker (127.0.0.11) toutes
# les 5 s et répartit la charge sur toutes les répliques du service `api`.
# Fonctionne avec 1 instance comme avec N (cf. docker-compose.scale.yml).
api.{$DOMAIN} {
	encode gzip
	reverse_proxy {
		dynamic a {
			name api
			port 8000
			refresh 5s
			resolvers 127.0.0.11
		}
		lb_policy round_robin

		# Résilience aux répliques défaillantes. On utilise un health-check PASSIF
		# (réactif aux échecs réels) plutôt qu'actif : les health-checks actifs de
		# Caddy se combinent mal aux upstreams dynamiques (les upstreams sont
		# recréés à chaque refresh DNS → fenêtre « no upstreams available »).
		#
		# - lb_try_duration : ré-essaie la requête sur une autre réplique (≤ 5 s),
		#   donc une réplique qui tombe ne provoque aucune erreur côté client.
		# - fail_duration / max_fails : éjecte une réplique 10 s après un échec.
		lb_try_duration 5s
		lb_try_interval 250ms
		fail_duration 10s
		max_fails 1
	}
}
